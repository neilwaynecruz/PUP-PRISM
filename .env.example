APP_NAME="PUP PRISM"
APP_ENV=local
# Production: generate a real application key with `php artisan key:generate --show`
# and store the resulting value here before caching config.
APP_KEY=
# Production: always set this to false.
APP_DEBUG=true
# Production: set this to your real HTTPS domain, e.g. https://prism.example.edu
APP_URL=http://localhost

APP_TIMEZONE=Asia/Manila
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pup_prism
DB_USERNAME=postgres
# Production: use a long, unique database password and never commit real credentials.
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Encrypt session payloads at rest. Enabling this in an existing environment
# invalidates all current sessions (everyone is logged out once).
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# Only send the session cookie over HTTPS. Set to true in production.
# Leave null/unset for local HTTP development, otherwise login breaks.
SESSION_SECURE_COOKIE=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# Production: use a persistent queue worker (Supervisor / Forge / Laravel Cloud / systemd)
# and make sure the jobs and failed_jobs tables are migrated before enabling this.
# The database queue driver requires the jobs table to exist on the target environment.
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=90
QUEUE_FAILED_DRIVER=database-uuids

# Production: consider Redis for cache/session/queue performance instead of the database store.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local default writes mail to logs. For a one-off Resend smoke test you may set:
# MAIL_MAILER=resend
# MAIL_FROM_ADDRESS=onboarding@resend.dev
# Resend only permits onboarding@resend.dev to send to your Resend account email.
# Production should use a real mailer such as Resend with your own verified sender address/domain.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Production: use a sender address/domain verified in Resend.
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
RESEND_API_KEY=

VITE_APP_NAME="${APP_NAME}"
REVERB_APP_ID=100001
REVERB_APP_KEY=changeme-reverb-key
REVERB_APP_SECRET=changeme-reverb-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
